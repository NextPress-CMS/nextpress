{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "paths": {
      "@/*": [
        "./"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@nextpress/core": [
        "../../packages/core/src"
      ],
      "@nextpress/core/*": [
        "../../packages/core/src/*"
      ],
      "@nextpress/db": [
        "../../packages/db/src"
      ],
      "@nextpress/db/*": [
        "../../packages/db/src/*"
      ],
      "@nextpress/api": [
        "../../packages/api/src"
      ],
      "@nextpress/api/*": [
        "../../packages/api/src/*"
      ],
      "@nextpress/blocks": [
        "../../packages/blocks/src"
      ],
      "@nextpress/blocks/*": [
        "../../packages/blocks/src/*"
      ],
      "@nextpress/editor": [
        "../../packages/editor/src"
      ],
      "@nextpress/editor/*": [
        "../../packages/editor/src/*"
      ],
      "@nextpress/ui": [
        "../../packages/ui/src"
      ],
      "@nextpress/ui/*": [
        "../../packages/ui/src/*"
      ]
    },
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "__tests__"
  ]
}
